# ─── OASIS API ───────────────────────────────────────────────────────────────
# Base URL for the OASIS remote API (no trailing slash)
OASIS_API_BASE=https://api.oasisweb4.com/api

# Service avatar — a dedicated OASIS account for the union-api bridge
# Register one at https://api.oasisweb4.com/api/avatar/register
OASIS_SERVICE_USERNAME=union-pdc-service
OASIS_SERVICE_PASSWORD=your-service-password-here

# ─── ZKTeco Fingerprint Device ───────────────────────────────────────────────
# Set ZKTECO_BRIDGE_ENABLED=true to poll the device every 5 min
ZKTECO_BRIDGE_ENABLED=false

# IP address of the fingerprint reader on the local network
ZKTECO_DEVICE_IP=192.168.1.100
ZKTECO_DEVICE_PORT=4370

# Which chapter this device is at (used in session holons)
DEFAULT_CHAPTER=PDC

# ─── STAR Quest IDs ──────────────────────────────────────────────────────────
# Run `npm run seed-quests` to create these and paste the IDs here
QUEST_ID_10_SESSIONS=
QUEST_ID_50_SESSIONS=
QUEST_ID_100_SESSIONS=
QUEST_ID_200_SESSIONS=
QUEST_ID_500_SESSIONS=
QUEST_ID_CROSS_CHAPTER=
QUEST_ID_REVIEW=
QUEST_ID_REFERRAL=

# ─── WhatsApp (Meta Cloud API — free) ────────────────────────────────────────
# Get these from developers.facebook.com → your app → WhatsApp → API Setup
# Jefferson: see JEFFERSON_BRIEFING.md for step-by-step setup instructions

# The numeric ID of your WhatsApp Business phone number
WHATSAPP_PHONE_NUMBER_ID=

# Access token from the Meta developer dashboard
WHATSAPP_ACCESS_TOKEN=

# A secret string YOU choose — enter the same value in Meta's webhook settings
WHATSAPP_VERIFY_TOKEN=union_webhook_verify

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001

# Path to local fingerprint→avatarId mapping file
LOCAL_DB_PATH=./data/db.json

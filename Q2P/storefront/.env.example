# Q2P Storefront (Next.js Commerce)
# Copy to .env.local and fill in values

# Medusa backend
NEXT_PUBLIC_MEDUSA_BACKEND_API=http://localhost:9000
MEDUSA_API_KEY=
MEDUSA_REVALIDATION_SECRET=supersecret123

# OASIS (for Q2P quest proofs & avatar)
NEXT_PUBLIC_OASIS_ONODE_URL=http://localhost:5004
NEXT_PUBLIC_OASIS_STAR_API_URL=http://localhost:50564
# Optional: OASIS avatar JWT for quest entitlements (dev). Production: use cookie oasis_token or portal embed.
# NEXT_PUBLIC_OASIS_AVATAR_TOKEN=

# Site
SITE_NAME="Q2P Shop"
NEXT_PUBLIC_VERCEL_URL=http://localhost:3000
TWITTER_CREATOR=@oasisplatform
TWITTER_SITE=https://oasisweb4.com
